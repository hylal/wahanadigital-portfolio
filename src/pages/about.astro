---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Tentang Saya">
  <div class="max-w-4xl mx-auto px-4 py-16">
    <!-- Header -->
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">Tentang Saya</h1>
      <p class="text-xl text-gray-600">Digital Marketing Professional dengan pengalaman lebih dari 15 tahun</p>
    </div>

    <!-- Content -->
    <div class="prose prose-lg max-w-none">
      <div class="bg-white rounded-xl shadow-sm p-8 mb-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Halo, Saya Hilaludin Wahid</h2>
        <p class="text-gray-700 mb-4">
          Saya adalah seorang Digital Marketing Professional yang telah berkecimpung di industri ini sejak tahun 2009. 
          Dengan latar belakang sebagai Head of IT dan Digital Marketing, saya memiliki pemahaman mendalam tentang 
          bagaimana teknologi dan pemasaran digital dapat bekerja bersama untuk mendorong pertumbuhan bisnis.
        </p>
        <p class="text-gray-700 mb-4">
          Keahlian utama saya mencakup SEO, SEM, periklanan online, dan arsitektur web modern. Saya juga merupakan 
          kontributor aktif di komunitas WordPress, termasuk tim Polyglots dan organizer WordPress NextGen Jakarta.
        </p>
      </div>

      <!-- Skills -->
      <div class="bg-white rounded-xl shadow-sm p-8 mb-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Keahlian</h2>
        <div class="grid md:grid-cols-2 gap-4">
          <div class="flex items-start">
            <svg class="w-6 h-6 text-blue-600 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <div>
              <h3 class="font-semibold text-gray-900">SEO & SEM</h3>
              <p class="text-gray-600 text-sm">Optimasi mesin pencari dan pemasaran berbayar</p>
            </div>
          </div>
          <div class="flex items-start">
            <svg class="w-6 h-6 text-blue-600 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <div>
              <h3 class="font-semibold text-gray-900">WordPress Development</h3>
              <p class="text-gray-600 text-sm">Headless CMS, Custom Theme, Plugin Development</p>
            </div>
          </div>
          <div class="flex items-start">
            <svg class="w-6 h-6 text-blue-600 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <div>
              <h3 class="font-semibold text-gray-900">Digital Strategy</h3>
              <p class="text-gray-600 text-sm">Perencanaan strategis berbasis data</p>
            </div>
          </div>
          <div class="flex items-start">
            <svg class="w-6 h-6 text-blue-600 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <div>
              <h3 class="font-semibold text-gray-900">Modern Web Architecture</h3>
              <p class="text-gray-600 text-sm">Astro, Next.js, Headless CMS, JAMstack</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Experience -->
      <div class="bg-white rounded-xl shadow-sm p-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Pengalaman Profesional</h2>
        <div class="space-y-6">
          <div class="border-l-4 border-blue-600 pl-4">
            <h3 class="font-bold text-lg text-gray-900">Head of IT & Digital Marketing</h3>
            <p class="text-gray-600">OB Fitness & Health</p>
            <p class="text-sm text-gray-500">Memimpin strategi digital dan infrastruktur IT</p>
          </div>
          <div class="border-l-4 border-blue-600 pl-4">
            <h3 class="font-bold text-lg text-gray-900">Senior Digital Marketing Supervisor</h3>
            <p class="text-gray-600">Berbagai Perusahaan</p>
            <p class="text-sm text-gray-500">2009 - Sekarang</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>