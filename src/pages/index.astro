---
import BaseLayout from '../layouts/BaseLayout.astro';
import { client } from '../lib/graphql';

const query = `
  query GetLatestPosts {
    posts(first: 3) {
      nodes {
        title
        slug
        excerpt
        date
      }
    }
  }
`;

let posts = [];
try {
  const data = await client.request(query);
  posts = data.posts.nodes;
} catch (error) {
  console.error("Gagal mengambil data:", error);
}
---

<BaseLayout title="Home">
  <!-- Hero Section -->
  <section class="bg-white py-20 lg:py-32">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <span class="inline-block py-1 px-3 rounded-full bg-blue-100 text-blue-700 text-sm font-semibold mb-4">
        Digital Marketing Professional
      </span>
      <h1 class="text-4xl md:text-6xl font-extrabold text-gray-900 tracking-tight mb-6">
        Membangun Pertumbuhan Bisnis Melalui <span class="text-blue-600">Strategi Digital</span>
      </h1>
      <p class="text-lg md:text-xl text-gray-600 mb-10 max-w-2xl mx-auto">
        Halo, saya Hilaludin Wahid. Berpengalaman lebih dari 15 tahun di bidang SEO, SEM, dan Arsitektur Web Modern.
      </p>
      <div class="flex justify-center gap-4">
        <a href="/portfolio" class="px-6 py-3 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition">
          Lihat Portofolio
        </a>
        <a href="/contact" class="px-6 py-3 bg-gray-100 text-gray-700 font-medium rounded-lg hover:bg-gray-200 transition">
          Hubungi Saya
        </a>
      </div>
    </div>
  </section>

  <!-- Latest Insights / Posts Section -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900">Artikel & Wawasan Terbaru</h2>
        <p class="mt-4 text-gray-600">Berbagi pemikiran seputar Digital Marketing dan Teknologi.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {posts.length > 0 ? (
          posts.map((post) => (
            <article class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition">
              <div class="p-6">
                <time class="text-sm text-gray-500 mb-2 block">
                  {new Date(post.date).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                <h3 class="text-xl font-bold text-gray-900 mb-3 line-clamp-2">
                  {post.title}
                </h3>
                <div class="text-gray-600 text-sm line-clamp-3 mb-4" set:html={post.excerpt}></div>
                <a href={`/blog/${post.slug}`} class="text-blue-600 font-medium hover:underline text-sm">
                  Baca Selengkapnya &rarr;
                </a>
              </div>
            </article>
          ))
        ) : (
          <p class="text-center col-span-3 text-gray-500">Belum ada artikel yang dipublikasikan.</p>
        )}
      </div>
    </div>
  </section>
</BaseLayout>