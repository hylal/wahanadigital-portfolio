---
import BaseLayout from '../layouts/BaseLayout.astro';
import { client } from '../lib/graphql';

// Fetch latest posts dari WordPress
const query = `
  query GetLatestPosts {
    posts(first: 3) {
      nodes {
        title
        slug
        excerpt
        date
        featuredImage {
          node {
            sourceUrl
            altText
          }
        }
      }
    }
  }
`;

let posts = [];
try {
  const data = await client.request(query);
  
  // Cek apakah data dan posts ada
  if (data && data.posts && data.posts.nodes) {
    posts = data.posts.nodes;
  }
} catch (error) {
  console.error("Gagal mengambil data:", error);
  posts = [];
}

// Data services
const services = [
  {
    icon: '🎯',
    title: 'SEO & SEM Strategy',
    description: 'Tingkatkan visibilitas online Anda dengan strategi SEO dan SEM yang terukur dan berbasis data untuk pertumbuhan bisnis yang berkelanjutan.'
  },
  {
    icon: '🚀',
    title: 'Digital Marketing',
    description: 'Kampanye digital yang komprehensif meliputi social media, content marketing, dan paid advertising untuk menjangkau audiens yang tepat.'
  },
  {
    icon: '💻',
    title: 'Web Development',
    description: 'Website modern dengan arsitektur headless CMS, performa tinggi, dan SEO-friendly menggunakan teknologi terkini seperti Astro dan Next.js.'
  }
];

// Data features
const features = [
  {
    number: '01',
    title: 'Strategic Planning',
    description: 'Perencanaan strategis berbasis riset pasar dan analisis kompetitor untuk memastikan setiap langkah marketing Anda tepat sasaran.'
  },
  {
    number: '02',
    title: 'Performance Optimization',
    description: 'Optimasi berkelanjutan berdasarkan data dan analytics untuk memaksimalkan ROI dan mencapai target bisnis Anda.'
  },
  {
    number: '03',
    title: 'Technical Implementation',
    description: 'Implementasi teknis yang solid dengan fokus pada performa website, user experience, dan technical SEO.'
  },
  {
    number: '04',
    title: 'Growth & Scaling',
    description: 'Strategi scaling yang terukur untuk membawa bisnis Anda ke level berikutnya dengan sistem yang sustainable.'
  }
];

// Data stats
const stats = [
  { value: '15+', label: 'Tahun Pengalaman' },
  { value: '100+', label: 'Project Selesai' },
  { value: '50+', label: 'Klien Puas' },
  { value: '300%', label: 'Avg. Traffic Growth' }
];
---

<BaseLayout title="Home" description="Digital Marketing Professional dengan pengalaman 15+ tahun dalam SEO, SEM, dan Web Development">
  
  <!-- Hero Section - Dark Green -->
  <section class="relative overflow-hidden bg-emerald-900 py-20 lg:py-32">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Left Content -->
        <div>
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-lime-400 rounded-full mb-6">
            <span class="w-2 h-2 bg-emerald-900 rounded-full animate-pulse"></span>
            <span class="text-sm font-semibold text-emerald-900">Available for Projects</span>
          </div>
          
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
            Digital Marketing
            <span class="text-lime-400">Solutions</span>
            <br />
            That Drive Growth
          </h1>
          
          <p class="text-lg md:text-xl text-emerald-100 mb-8 leading-relaxed">
            Membantu bisnis Anda berkembang melalui strategi digital yang terukur, 
            implementasi teknis yang solid, dan optimasi berkelanjutan berbasis data.
          </p>
          
          <div class="flex flex-col sm:flex-row gap-4 mb-8">
            <a href="https://wa.me/6285888888465" target="_blank" class="px-8 py-4 bg-lime-400 text-emerald-900 font-semibold rounded-lg hover:bg-lime-300 transition shadow-lg hover:shadow-xl text-center">
              Konsultasi Gratis
            </a>
            <a href="/portfolio" class="px-8 py-4 bg-emerald-800 text-white font-semibold rounded-lg hover:bg-emerald-700 transition border-2 border-emerald-700 text-center">
              Lihat Portofolio
            </a>
          </div>
          
          <div class="flex items-center gap-6 text-sm text-emerald-100">
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-lime-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span>No commitment</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-lime-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span>Free consultation</span>
            </div>
          </div>
        </div>
        
        <!-- Right Content - Stats -->
        <div class="grid grid-cols-2 gap-6">
          {stats.map((stat) => (
            <div class="bg-white/10 backdrop-blur-sm p-6 rounded-xl border border-emerald-700">
              <div class="text-3xl md:text-4xl font-bold text-lime-400 mb-2">{stat.value}</div>
              <div class="text-sm text-emerald-100">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section - Lime Green -->
  <section class="py-20 bg-lime-400">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-emerald-900 mb-4">
          Layanan Profesional
        </h2>
        <p class="text-lg text-emerald-800 max-w-2xl mx-auto">
          Solusi digital komprehensif untuk membantu bisnis Anda tumbuh dan berkembang di era digital
        </p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8">
        {services.map((service) => (
          <div class="group p-8 bg-white rounded-xl hover:shadow-xl transition border-2 border-emerald-100 hover:border-emerald-300">
            <div class="text-5xl mb-4">{service.icon}</div>
            <h3 class="text-xl font-bold text-emerald-900 mb-3 group-hover:text-emerald-700 transition">
              {service.title}
            </h3>
            <p class="text-gray-600 leading-relaxed">
              {service.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features Section - White -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-emerald-900 mb-4">
          Pendekatan Strategis
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Metodologi yang terstruktur untuk memastikan setiap project mencapai hasil optimal
        </p>
      </div>
      
      <div class="grid md:grid-cols-2 gap-8">
        {features.map((feature) => (
          <div class="flex gap-6 p-6 bg-emerald-50 rounded-xl border-2 border-emerald-100 hover:border-emerald-300 hover:shadow-lg transition">
            <div class="flex-shrink-0">
              <div class="w-12 h-12 bg-emerald-900 text-lime-400 font-bold rounded-lg flex items-center justify-center text-lg">
                {feature.number}
              </div>
            </div>
            <div>
              <h3 class="text-xl font-bold text-emerald-900 mb-2">{feature.title}</h3>
              <p class="text-gray-700 leading-relaxed">{feature.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Latest Articles Section - Dark Green -->
  <section class="py-20 bg-emerald-900">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
          Artikel & Insights Terbaru
        </h2>
        <p class="text-lg text-emerald-100 max-w-2xl mx-auto">
          Berbagi pengetahuan dan pengalaman seputar digital marketing dan teknologi
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {posts.length > 0 ? (
          posts.map((post) => {
            const imageUrl = post.featuredImage?.node?.sourceUrl || null;
            const imageAlt = post.featuredImage?.node?.altText || post.title;
            
            return (
              <article class="group bg-white rounded-xl overflow-hidden hover:shadow-xl transition border-2 border-emerald-700">
                {/* Featured Image */}
                {imageUrl ? (
                  <div class="relative overflow-hidden aspect-video">
                    <img 
                      src={imageUrl} 
                      alt={imageAlt}
                      class="w-full h-full object-cover group-hover:scale-105 transition duration-300"
                      loading="lazy"
                    />
                  </div>
                ) : (
                  <div class="relative overflow-hidden aspect-video bg-gradient-to-br from-emerald-800 to-emerald-600">
                    <div class="absolute inset-0 flex items-center justify-center">
                      <svg class="w-16 h-16 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                      </svg>
                    </div>
                  </div>
                )}
                
                <div class="p-6">
                  <time class="text-sm text-emerald-600 mb-3 block font-medium">
                    {new Date(post.date).toLocaleDateString('id-ID', { 
                      year: 'numeric', 
                      month: 'long', 
                      day: 'numeric' 
                    })}
                  </time>
                  <h3 class="text-xl font-bold text-emerald-900 mb-3 group-hover:text-emerald-700 transition line-clamp-2">
                    {post.title}
                  </h3>
                  <div class="text-gray-600 text-sm line-clamp-3 mb-4" set:html={post.excerpt}></div>
                  <a href={`/blog/${post.slug}`} class="inline-flex items-center text-emerald-700 font-semibold hover:text-emerald-900 transition">
                    Baca Selengkapnya
                    <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                  </a>
                </div>
              </article>
            );
          })
        ) : (
          <div class="col-span-3 text-center py-12">
            <p class="text-emerald-200">Belum ada artikel yang dipublikasikan.</p>
          </div>
        )}
      </div>
      
      <div class="text-center mt-12">
        <a href="/blog" class="inline-flex items-center px-6 py-3 bg-lime-400 text-emerald-900 font-semibold rounded-lg hover:bg-lime-300 transition">
          Lihat Semua Artikel
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section - Lime Green -->
  <section class="py-20 bg-lime-400">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-emerald-900 mb-6">
        Siap Membawa Bisnis Anda ke Level Berikutnya?
      </h2>
      <p class="text-xl text-emerald-800 mb-8">
        Mari diskusikan bagaimana saya bisa membantu Anda mencapai target bisnis melalui strategi digital yang efektif
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://wa.me/6285888888465" target="_blank" class="px-8 py-4 bg-emerald-900 text-white font-semibold rounded-lg hover:bg-emerald-800 transition shadow-lg">
          Mulai Konsultasi
        </a>
        <a href="/portfolio" class="px-8 py-4 bg-white text-emerald-900 font-semibold rounded-lg hover:bg-gray-100 transition border-2 border-emerald-900">
          Lihat Portofolio
        </a>
      </div>
    </div>
  </section>

</BaseLayout>