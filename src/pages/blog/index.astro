---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { client } from '../../lib/graphql';

// Fetch semua posts dari WordPress (dengan featured image)
const query = `
  query GetAllPosts {
    posts(first: 50) {
      nodes {
        title
        slug
        excerpt
        date
        featuredImage {
          node {
            sourceUrl
            altText
            mediaDetails {
              width
              height
            }
          }
        }
        author {
          node {
            name
          }
        }
      }
    }
  }
`;

let posts = [];
try {
  const data = await client.request(query);
  
  // Cek apakah data dan posts ada
  if (data && data.posts && data.posts.nodes) {
    posts = data.posts.nodes;
  }
} catch (error) {
  console.error("Gagal mengambil data posts:", error);
  posts = [];
}

// Group posts by year
const postsByYear = posts.reduce((acc, post) => {
  const year = new Date(post.date).getFullYear();
  if (!acc[year]) {
    acc[year] = [];
  }
  acc[year].push(post);
  return acc;
}, {});

const years = Object.keys(postsByYear).sort((a, b) => b - a);
---

<BaseLayout title="Blog" description="Artikel dan insights seputar digital marketing, SEO, dan web development">
  
  <!-- Hero Section -->
  <section class="bg-emerald-900 py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">
          Blog & <span class="text-lime-400">Insights</span>
        </h1>
        <p class="text-lg text-emerald-100 max-w-2xl mx-auto">
          Berbagi pengetahuan dan pengalaman seputar digital marketing, SEO, dan teknologi web modern
        </p>
      </div>
    </div>
  </section>

  <!-- Blog Listing Section -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      
      {posts.length === 0 ? (
        <div class="text-center py-20">
          <div class="text-6xl mb-4">📝</div>
          <h2 class="text-2xl font-bold text-gray-900 mb-2">Belum Ada Artikel</h2>
          <p class="text-gray-600">Artikel akan segera hadir. Stay tuned!</p>
        </div>
      ) : (
        <div class="space-y-16">
          {years.map((year) => (
            <div>
              <!-- Year Header -->
              <div class="flex items-center gap-4 mb-8">
                <h2 class="text-3xl font-bold text-emerald-900">{year}</h2>
                <div class="flex-1 h-0.5 bg-emerald-200"></div>
                <span class="text-sm text-gray-500">{postsByYear[year].length} artikel</span>
              </div>

              <!-- Posts Grid -->
              <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
                {postsByYear[year].map((post) => {
                  const imageUrl = post.featuredImage?.node?.sourceUrl || null;
                  const imageAlt = post.featuredImage?.node?.altText || post.title;
                  
                  return (
                    <article class="group bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-lg transition">
                      {/* Featured Image */}
                      {imageUrl ? (
                        <div class="relative overflow-hidden aspect-video">
                          <img 
                            src={imageUrl} 
                            alt={imageAlt}
                            class="w-full h-full object-cover group-hover:scale-105 transition duration-300"
                            loading="lazy"
                          />
                        </div>
                      ) : (
                        /* Fallback jika tidak ada featured image */
                        <div class="relative overflow-hidden aspect-video bg-gradient-to-br from-emerald-900 to-emerald-700">
                          <div class="absolute inset-0 flex items-center justify-center">
                            <svg class="w-16 h-16 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                            </svg>
                          </div>
                        </div>
                      )}
                      
                      <div class="p-6">
                        <time class="text-sm text-emerald-600 mb-3 block font-medium">
                          {new Date(post.date).toLocaleDateString('id-ID', { 
                            year: 'numeric', 
                            month: 'long', 
                            day: 'numeric' 
                          })}
                        </time>
                        
                        <h3 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-emerald-700 transition line-clamp-2">
                          {post.title}
                        </h3>
                        
                        <div class="text-gray-600 text-sm line-clamp-3 mb-4" set:html={post.excerpt}></div>
                        
                        <div class="flex items-center justify-between pt-4 border-t border-gray-100">
                          <span class="text-xs text-gray-500">
                            Oleh {post.author.node.name}
                          </span>
                          <a 
                            href={`/blog/${post.slug}`} 
                            class="inline-flex items-center text-emerald-700 font-semibold hover:text-emerald-900 transition text-sm"
                          >
                            Baca
                            <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                            </svg>
                          </a>
                        </div>
                      </div>
                    </article>
                  );
                })}
              </div>
            </div>
          ))}
        </div>
      )}

      <!-- CTA Section -->
      <div class="mt-20 text-center">
        <div class="bg-emerald-900 rounded-2xl p-12">
          <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">
            Ingin Konsultasi Gratis?
          </h2>
          <p class="text-emerald-100 mb-8 max-w-2xl mx-auto">
            Mari diskusikan bagaimana saya bisa membantu bisnis Anda berkembang melalui strategi digital yang efektif
          </p>
          <a 
            href="https://wa.me/6285888888465" 
            target="_blank"
            class="inline-block px-8 py-4 bg-lime-400 text-emerald-900 font-semibold rounded-lg hover:bg-lime-300 transition shadow-lg"
          >
            Hubungi via WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>